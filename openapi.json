    "/parse/batch": {
      "post": {
        "tags": [
          "Parse"
        ],
        "summary": "Parse Batch",
        "description": "Parse multiple resumes in a single request (up to 10 files)\n\nThis endpoint allows you to process multiple resumes at once, which is useful for:\n- Bulk processing of resumes\n- Batch uploads from job portals\n- Processing multiple candidates at once\n\nSupports:\n- PDF files\n- DOCX files\n- Maximum 10 files per request\n\nReturns structured data for each resume including:\n- Contact information\n- Professional summary\n- Work experience\n- Education\n- Skills\n- Certifications\n\nEach file is processed independently - if one fails, others will still be processed.",
        "operationId": "parse_batch_parse_batch_post",
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "parameters": [
          {
            "name": "include_raw_text",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "description": "Include raw text in response",
              "default": false,
              "title": "Include Raw Text"
            },
            "description": "Include raw text in response"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_parse_batch_parse_batch_post"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
